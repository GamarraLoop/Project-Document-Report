rectangle "Dispositivo móvil del usuario\n<size:16>[Deployment Node: Android 8+ / iOS 14+]</size>" <<DeploymentNode-RWxlbWVudA==>> as Production.Dispositivomóvildelusuario {
  rectangle "==Mobile App\n<size:16>[Container: Flutter (FlutterFlow) / Dart]</size>\n\nAplicación móvil multiplataforma para Confeccionistas y Artesanos. Captura foto y ubicación GPS del lote, consume el catálogo geolocalizado, gestiona reservas y recibe notificaciones push del recojo." <<Element-RWxlbWVudCxNb2JpbGU=>> as Production.Dispositivomóvildelusuario.MobileApp_1
}

rectangle "GitHub Pages\n<size:16>[Deployment Node: CDN global de GitHub]</size>" <<DeploymentNode-RWxlbWVudCxFeHRlcm5hbA==>> as Production.GitHubPages {
  rectangle "==Landing Page\n<size:16>[Container: HTML5 / CSS3 / JavaScript]</size>\n\nSitio estático informativo del proyecto Gamarra Loop / ReciTex. Presenta la propuesta de valor a Confeccionistas, Artesanos y stakeholders externos. No realiza llamadas al backend." <<Element-RWxlbWVudCxXZWI=>> as Production.GitHubPages.LandingPage_1
}

rectangle "Google Cloud Platform\n<size:16>[Deployment Node: Región us-central1]</size>" <<DeploymentNode-RWxlbWVudCxHQ1A=>> as Production.GoogleCloudPlatform {
  rectangle "Cloud Run\n<size:16>[Deployment Node: Cloud Run]</size>" <<DeploymentNode-RWxlbWVudA==>> as Production.GoogleCloudPlatform.CloudRun {
    hexagon "==API REST\n<size:16>[Container: Spring Boot / Java 21]</size>\n\nBackend monolítico modular que expone endpoints REST autenticados con JWT. Internamente se organiza en 7 bounded contexts (User Profile, Lot Publication, Textile Classification, Reservation, Pickup and Delivery, Expiration, Notification — ver Capítulo V) bajo el patrón Hexagonal Port + Adapter decidido en la sección 4.1.4." <<Element-RWxlbWVudCxBUEk=>> as Production.GoogleCloudPlatform.CloudRun.APIREST_1
  }

  rectangle "==Google Cloud Vision\n<size:16>[Software System]</size>\n\nServicio gestionado de Google que clasifica automáticamente imágenes de textiles y devuelve etiquetas y niveles de confianza sobre el material y color del lote." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.GoogleCloudVision_1
  rectangle "==Firebase Authentication\n<size:16>[Software System]</size>\n\nServicio gestionado de Google que emite y valida JWT anónimos para identificar a Confeccionistas y Artesanos sin gestión de contraseñas." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.FirebaseAuthentication_1
  rectangle "==Google Cloud Storage\n<size:16>[Software System]</size>\n\nServicio gestionado de Google para almacenar imágenes originales y miniaturas (thumbnails) de los lotes publicados por los Confeccionistas." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.GoogleCloudStorage_1
  rectangle "==Google Cloud Pub/Sub\n<size:16>[Software System]</size>\n\nServicio gestionado de Google de mensajería asíncrona para desacoplar la publicación de lotes de la clasificación con IA y de las notificaciones." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.GoogleCloudPubSub_1
  rectangle "==Google Maps Platform\n<size:16>[Software System]</size>\n\nServicio gestionado de Google que provee renderizado de mapas, geocoding inverso y referencias geográficas para localizar lotes y rutas de recojo." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.GoogleMapsPlatform_1
  rectangle "==Firebase Cloud Messaging\n<size:16>[Software System]</size>\n\nServicio gestionado de Google para entregar notificaciones push a los dispositivos móviles de Confeccionistas y Artesanos." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsR0NQ>> as Production.GoogleCloudPlatform.FirebaseCloudMessaging_1
}

rectangle "Supabase Cloud\n<size:16>[Deployment Node: Región us-east-1]</size>" <<DeploymentNode-RWxlbWVudCxFeHRlcm5hbA==>> as Production.SupabaseCloud {
  database "==Supabase Postgres\n<size:16>[Software System]</size>\n\nServicio gestionado externo (no GCP) que provee PostgreSQL con la extensión PostGIS para consultas geoespaciales por proximidad." <<Element-RWxlbWVudCxTb2Z0d2FyZSBTeXN0ZW0sRXh0ZXJuYWwsRGF0YWJhc2U=>> as Production.SupabaseCloud.SupabasePostgres_1
}

